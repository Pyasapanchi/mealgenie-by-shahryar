generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Application user synced from Clerk (auth handled by Clerk, not custom logic).
model User {
  id            String         @id @default(cuid())
  clerkId       String         @unique
  email         String         @unique
  firstName     String?
  lastName      String?
  imageUrl      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  favorites     Favorite[]
  conversations Conversation[]
  mealPlans     MealPlan[]
  savedRecipes  SavedRecipe[]
  preferences   Preferences?
}

model Recipe {
  id           String        @id @default(cuid())
  externalId   Int?
  source       RecipeSource  @default(LOCAL)
  name         String
  type         String
  cuisine      String?
  timeMinutes  Int?
  difficulty   String?
  calories     Int?
  icon         String?
  payload      Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  favorites    Favorite[]
  savedRecipes SavedRecipe[]
  mealPlans    MealPlan[]

  @@index([source, externalId])
  @@index([type])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
  @@index([userId])
}

model SavedRecipe {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
  @@index([userId])
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MealPlan {
  id        String    @id @default(cuid())
  userId    String
  recipeId  String?
  name      String
  planDate  DateTime?
  mealType  MealType?
  payload   Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe?   @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@index([userId, planDate])
}

model Preferences {
  id              String   @id @default(cuid())
  userId          String   @unique
  language        String   @default("en")
  backgroundColor String   @default("#FEF9F3")
  voiceMuted      Boolean  @default(false)
  payload         Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum RecipeSource {
  LOCAL
  SPOONACULAR
  GENERATED
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  DRINK
}
